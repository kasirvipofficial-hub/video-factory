# Clipper configuration

# Server
PORT=8080
NODE_ENV=development
API_BEARER_TOKEN=change-me

# Redis / Queue
REDIS_URL=redis://redis:6379
REDIS_PREFIX=clipper
CLIP_QUEUE_NAME=clip.jobs
RENDER_QUEUE_NAME=clip.render
WEBHOOK_QUEUE_NAME=clip.webhooks
FALLBACK_QUEUE_NAME=clip.fallbacks
CLIP_WORKER_CONCURRENCY=1
RENDER_WORKER_CONCURRENCY=1
WEBHOOK_WORKER_CONCURRENCY=3
DEFAULT_TENANT_ID=default

# YouTube & Video Download
YT_DLP_PATH=yt-dlp
COOKIES_FILE=./cookies.txt

# FFmpeg
FFMPEG_PATH=ffmpeg
PORTRAIT_OUTPUT_WIDTH=1080
PORTRAIT_OUTPUT_HEIGHT=1920
PORTRAIT_VIDEO_PRESET=veryfast
PORTRAIT_VIDEO_CRF=20
PORTRAIT_RENDER_TIMEOUT_MS=600000

# Face / Person Detection
FACE_DETECTOR_BACKEND=heuristic
FACE_DETECTOR_SAMPLE_INTERVAL_SECONDS=1
YOLO_PYTHON_PATH=python
YOLO_SCRIPT_PATH=./scripts/yolo_person_detect.py
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_MAX_FRAMES=90
YOLO_TIMEOUT_MS=180000
YOLO_IMAGE_SIZE=640
YOLO_DEVICE=

# AI Analysis
AI_API_BASE_URL=https://your-ai-endpoint.example/v1
AI_API_KEY=replace-with-real-key
AI_MODEL=seed-2-0-mini-free
AI_DATA_TIMEOUT_MS=300000
AI_DIRECTOR_TIMEOUT_MS=180000

# TTS
TTS_PROVIDER=huggingface
HUGGINGFACE_API_KEY=replace-with-real-key
OPENAI_TTS_API_KEY=

# Whisper (Transcription)
WHISPER_API_URL=https://your-whisper-endpoint.example/v1
WHISPER_API_KEY=replace-with-real-key
WHISPER_TIMEOUT_MS=600000
WHISPER_MAX_FILE_MB=20
WHISPER_CHUNK_SECONDS=480
WHISPER_AUDIO_BITRATE=64k
WHISPER_AUDIO_SAMPLE_RATE=16000

# Music / Fonts
MUSIC_DIR=./assets/music
USE_BACKGROUND_MUSIC=true
FONTS_DIR=./assets/fonts

# Working directories
OUTPUT_DIR=./output
TEMP_DIR=./temp
RESULTS_DIR=./results
CLEANUP_TEMP_FILES=true
CLEANUP_RESULT_FILES=true

# Clip duration constraints
MAX_DURATION=180
MIN_OUTPUT_DURATION=60
MAX_OUTPUT_DURATION=180
DISCOVERY_MIN_VIDEO_SECONDS=600
DISCOVERY_SELECTION_TIMEOUT_MS=120000
DISCOVERY_VISION_RERANK_ENABLED=false
DISCOVERY_VISION_RERANK_TOP_N=3
WEBHOOK_MAX_RETRIES=5
JOB_STALE_AFTER_MS=900000

# Logging
LOG_LEVEL=info

# Cloudflare R2 / S3-compatible storage
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=clipper-results
S3_ACCESS_KEY=replace-with-r2-access-key
S3_SECRET_KEY=replace-with-r2-secret-key
S3_PUBLIC_URL=https://cdn.example.com
S3_REGION=auto
S3_UPLOAD_PREFIX=clipper
S3_UPLOAD_TIMEOUT_MS=180000
S3_UPLOAD_MAX_RETRIES=2
