{
  "name": "clipper",
  "version": "1.0.0",
  "description": "YouTube Video Clipper - AI-powered highlight extraction and video generation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:worker": "ts-node src/workers/clip.worker.ts",
    "dev:render-worker": "ts-node src/workers/render.worker.ts",
    "dev:webhooks": "ts-node src/workers/webhook.worker.ts",
    "dev:webhook-dummy": "ts-node src/examples/webhook-dummy.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/workers/clip.worker.js",
    "start:render-worker": "node dist/workers/render.worker.js",
    "start:webhooks": "node dist/workers/webhook.worker.js",
    "start:webhook-dummy": "node dist/examples/webhook-dummy.js",
    "clip": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "axios": "^1.7.7",
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "ioredis": "^5.10.0",
    "node-gtts": "^2.0.2",
    "openai": "^6.26.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@gradio/client": "^2.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
